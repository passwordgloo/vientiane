\n    Sheets(Sheets.Count).Name = Sheet1.Range(\"a1\")\nEnd If\n\nNext\n\nEnd Sub\n```","excerpt":"","tasklists":0,"title":"","headers":[{"level":2,"title":"选中单元格","slug":"选中单元格","link":"#选中单元格","children":[]},{"level":2,"title":"偏移","slug":"偏移","link":"#偏移","children":[]},{"level":2,"title":"筛选","slug":"筛选","link":"#筛选","children":[]},{"level":2,"title":"新建表","slug":"新建表","link":"#新建表","children":[]}]}}
