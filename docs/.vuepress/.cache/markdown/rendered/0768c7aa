> \"False\" Then\n    For i = LBound(arr) To UBound(arr)\n        Set wb = Workbooks.Open(arr(i))\n        \n        \n'#######################\n'这里针对打开的WB进行操作\n'#######################\n        \n        wb.Close\n    Next\n\nEnd If\n\nEnd Sub\n```\n\n## Application.dialogs\n\n```vb\nSub test()\n\n  Application.Dialogs(5).Show// [!code focus]\n\nEnd Sub\n```","excerpt":"","tasklists":0,"title":"","headers":[{"level":2,"title":"MsgBox","slug":"msgbox","link":"#msgbox","children":[]},{"level":2,"title":"Inputbox","slug":"inputbox","link":"#inputbox","children":[]},{"level":2,"title":"GetOpenFileName","slug":"getopenfilename","link":"#getopenfilename","children":[]},{"level":2,"title":"Application.dialogs","slug":"application-dialogs","link":"#application-dialogs","children":[]}]}}
